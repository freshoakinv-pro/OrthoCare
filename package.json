{
  "name": "orthocare-orchestrator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @orthocare/shared build && pnpm --filter @orthocare/server build && pnpm --filter @orthocare/client build",
    "start": "pnpm --filter @orthocare/server start",
    "dev": "concurrently -n server,client -c blue,green \"pnpm --filter @orthocare/server dev\" \"pnpm --filter @orthocare/client dev\"",
    "db:generate": "pnpm --filter @orthocare/server db:generate",
    "db:migrate": "pnpm --filter @orthocare/server db:migrate",
    "db:seed": "pnpm --filter @orthocare/server db:seed",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
